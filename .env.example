# Variables d'environnement — Point Chaud
# Copier en `.env.local` et remplir. NE JAMAIS committer de vraies valeurs.

# Supabase (branché à la fin du build — voir docs/DEPLOYMENT.md)
# Clé PUBLIQUE (anon) uniquement côté frontend. La clé service_role ne doit JAMAIS
# apparaître ici ni dans le code frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Bascule mock / réel : "mock" tant que Supabase n'est pas branché
VITE_DATA_SOURCE=mock
