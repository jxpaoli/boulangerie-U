# Variables d'environnement — Point Chaud
# Copier en `.env.local` et remplir. NE JAMAIS committer de vraies valeurs.
# `.env.local` est ignoré par git.

# Supabase — base PARTAGÉE, schéma isolé `point_chaud`
# URL du projet (publique) :
VITE_SUPABASE_URL=https://lrittnexagnqcnnxbzrx.supabase.co
# Clé PUBLIQUE (anon) — à copier depuis Dashboard > Settings > API.
# La clé service_role ne doit JAMAIS apparaître ici ni dans le frontend.
VITE_SUPABASE_ANON_KEY=

# Bascule mock / réel : "mock" tant que Supabase n'est pas branché,
# sinon laisser vide / "supabase".
VITE_DATA_SOURCE=mock
